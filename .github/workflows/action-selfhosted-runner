# testing self hosted runner....

name: my first github actions project

on: 
  push:
    branches: [main]
  
jobs:
  build: 
    runs-on: self-hosted

    strategy:
      matrix:
        python-version: ["3.14", "3.13"]

    steps:
    - name: checkout repository
      uses: actions/checkout@v4

    - name: set up python
      uses: actions/setup-python@v5
      with:
        python-version: ${{ matrix.python-version }}

    - name: install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install pytest

    - name: run test
      run: |
        python -m pytest apps/addition.py
